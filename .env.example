# CVR Resolve Environment Configuration
# Copy this to .env and fill in your values

# Supabase Database Configuration
# Get DATABASE_URL from: https://app.supabase.com -> Project Settings -> Database
# IMPORTANT: URL-encode special characters in password (e.g., @ becomes %40)
DATABASE_URL=postgresql://postgres:your_password@your_host.supabase.co:5432/postgres

# Optional: Supabase Connection Pooler (faster for serverless)
# Get from: https://app.supabase.com -> Project Settings -> Database -> Connection String (pgBouncer)
# DATABASE_URL_POOLER=postgresql://postgres:your_password@your_host.supabase.co:6543/postgres

# Supabase API Configuration
SUPABASE_URL=https://your_project_id.supabase.co
SUPABASE_KEY=your_anon_key

# Flask Configuration
FLASK_ENV=development
FLASK_SECRET_KEY=your_secret_key_here_min_32_chars
PORT=5050

# Optional: Allowed email domains for student registration
# Format: domain1@example.com,domain2@example.com,gmail.com
ALLOWED_STUDENT_DOMAINS=@student.cvr.ac.in,@cvr.ac.in,gmail.com
